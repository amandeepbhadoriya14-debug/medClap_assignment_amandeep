# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# Public base URL of the app (used to build the Google OAuth redirect URI).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth credentials (from https://console.cloud.google.com/apis/credentials).
# Authorised redirect URI must be:  <NEXT_PUBLIC_APP_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: override where the JSON "database" file is written.
# DB_PATH=./data/db.json
